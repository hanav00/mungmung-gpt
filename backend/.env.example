# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 비전 모델명 (기본: gpt-4.1-mini)
VISION_MODEL=gpt-4.1-mini

# 텍스트 임베딩 모델 (RAG 지식 인덱싱/검색용)
EMBEDDING_MODEL=text-embedding-3-small

# RAG top-k (검색된 지식 조각 수)
RETRIEVE_TOP_K=5

# 이미지 리사이즈 최대 변 길이 (px)
MAX_IMAGE_SIDE=1024

# JPEG 재인코딩 품질 (1-95)
JPEG_QUALITY=85

# CORS 허용 Origin (쉼표 구분)
CORS_ORIGINS=http://localhost:3000

# (선택) LangFuse 관측
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

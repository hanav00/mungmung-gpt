# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-...

# 비전 모델명 (기본: gpt-4.1-mini)
VISION_MODEL=gpt-4.1-mini

# 이미지 리사이즈 최대 변 길이 (px)
MAX_IMAGE_SIDE=1024

# JPEG 재인코딩 품질 (1-95)
JPEG_QUALITY=85

# CORS 허용 Origin (쉼표 구분)
CORS_ORIGINS=http://localhost:3000

# (선택) LangFuse 관측
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
